// Set parameter N = 4 (number of bits in the shift register)
parameter N=4;

// Define the module 'siso' (Serial-In Serial-Out shift register)
module siso(clk, rst, sin, q);

  // Inputs: clock, reset, and serial input
  input clk, rst, sin;

  // Output: serial output
  output q;

  // Temporary register of N bits to hold shifted values
  reg [(N-1):0] temp;

  // Always block triggered on rising edge of clock or reset
  always@(posedge clk or posedge rst)
    begin
      if(rst)
        // Clear the register when reset is active
        temp <= 0;
      else
        // Shift right and load new input bit at MSB
        temp <= {sin, temp[(N-1):1]};
    end
  // Output the least significant bit of the register
  assign q = temp[0];
endmodule
// The Test Bench code for the verification the design
// Testbench for the SISO (Serial-In Serial-Out) shift register
module tb();

  // Declare input signals as registers
  reg clk, rst, sin;

  // Declare output signal as wire
  wire q;

  // Instantiate the DUT (Device Under Test)
  siso DUT(clk, rst, sin, q);

  // Generate clock: toggles every 5 time units
  always #5 clk = ~clk;

  // Initial block for stimulus
  initial
    begin
      // Create waveform dump file for simulation
      $dumpfile("dump.vcd");
      $dumpvars(1);
      // Apply reset at start
      clk = 0; rst = 1; #10 rst = 0;
      // Apply serial input values one by one
      sin = 1; #10;
      sin = 0; #10;
      sin = 1; #10;
      sin = 0; #10;
      // Wait some time before ending simulation
      #40 $finish;
    end
  // Monitor values of signals during simulation
  initial
    $monitor("clk=%b rst=%b sin=%b q=%b", clk, rst, sin, q);
endmodule
