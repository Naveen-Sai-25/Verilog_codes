// Design code for N bit ripple carry adder
parameter N = 16;   // Set adder size to 16 bits
// Full adder: adds 1-bit a, b, and carry-in
module full_adder(a, b, cin, sum, carry);
  input a, b, cin;       // Inputs
  output sum, carry;     // Outputs

  assign sum   = a ^ b ^ cin;              // Sum = XOR of inputs
  assign carry = (a & b) | (cin & (a ^ b)); // Carry logic
endmodule

// 16-bit ripple-carry adder
module adder16_bit(a, b, cin, sum, cout);
  input  [(N-1):0] a, b;   // 16-bit inputs
  input  cin;              // Carry-in
  output [(N-1):0] sum;    // 16-bit sum
  output cout;             // Final carry-out

  wire [N:0] carry;        // Carry chain
  assign carry[0] = cin;   // First carry = input carry

  genvar i;
  generate
    for(i = 0; i < N; i = i + 1) 
      begin : bit_adder
        // Add each bit with carry
        full_adder fa(a[i], b[i], carry[i], sum[i], carry[i+1]);
      end
  endgenerate

  assign cout = carry[N];  // Last carry-out
endmodule
