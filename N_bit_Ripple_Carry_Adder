// Testbench for 16-bit adder
module tb();
  reg [15:0] a, b;     // 16-bit input registers
  reg cin;             // Carry-in register
  wire [15:0] sum;     // 16-bit sum output
  wire carry;          // Carry-out output

  // Instantiate the 16-bit adder (DUT = Device Under Test)
  adder16_bit DUT (a, b, cin, sum, carry);

  // Apply test values
  initial 
    begin
      a   = 16'd12;    // First input = 12
      b   = 16'd12;    // Second input = 12
      cin = 1'b1;      // Carry-in = 1
    end

  // Monitor outputs continuously
  initial
    $monitor("a=%b, b=%b, cin=%b | sum=%b, carry=%b", a, b, cin, sum, carry);
endmodule
