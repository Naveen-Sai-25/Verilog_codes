// Design Code for The Grey to Binary Code Converter
// Set bit-width
parameter N=4;

module binary(in, out);
  // Input of N bits
  input [(N-1):0] in;
  // Output of N bits
  output reg [(N-1):0] out;

  // Run whenever input changes
  always @(*) begin
    // Copy MSB directly
    out[3] = in[3];

    // Loop from N-2 down to 0
    for (int i = N-2; i >= 0; i--) begin
      // Each output bit = next output bit XOR input bit
      out[i] = out[i+1] ^ in[i];
    end
  end
endmodule
// Test Bench code for Verification of Design
// Testbench module (no inputs/outputs)
module tb();

  // Declare input register of N bits
  reg [N-1:0] in;
  // Declare output wire of N bits
  wire [N-1:0] out;

  // Instantiate the design under test (DUT)
  binary DUT(in, out);

  // Stimulus block: apply values to 'in'
  initial begin
    // Loop through values 0 to 15
    for (int i = 0; i < 16; i++) begin
      in = i;   // assign input
      #5;       // wait 5 time units
    end
  end

  // Monitor block: print values of input and output
  initial begin
    $monitor("Gray=%b Binary=%b", in, out);
  end

endmodule
