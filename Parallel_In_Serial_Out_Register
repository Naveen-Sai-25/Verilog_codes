// Parameterized Parallel-In Serial-Out (PISO) Register
parameter N = 4;   // Width of the register (default = 4 bits)

module piso(clk, rst, ena, sin, q);
  input clk, rst, ena;          // Clock, reset, and enable signals
  input [N-1:0] sin;            // N-bit parallel input data
  reg [N-1:0] temp;             // Temporary register to hold data
  output reg q;                 // Serial output (1-bit)

  // Sequential logic: triggered on rising edge of clock or reset
  always @(posedge clk or posedge rst)
    begin
      if (rst)                  // If reset is active
        temp <= 0;              // Clear the temporary register
      else if (ena)             // If enable is high
        temp <= sin;            // Load parallel input into temp register
      else
        // Shift operation: right shift by 1 bit
        // MSB is filled with 0, LSB moves out to q
        temp <= {1'b0, temp[N-1:1]};
    end

  // Assign the least significant bit (LSB) of temp to output q
  assign q = temp[0];

endmodule
// Test Bench code for the verifiaction of the Design
// Testbench for Parallel-In Serial-Out (PISO) Register
module tb();
  reg clk, rst, ena;           // Clock, reset, and enable signals
  reg [(N-1):0] sin;           // N-bit parallel input data
  wire q;                      // Serial output from DUT

  // Instantiate the Device Under Test (DUT)
  piso DUT(clk, rst, ena, sin, q);

  // Clock generation: toggles every 5 time units
  always #5 clk = ~clk;

  // Initial block for stimulus
  initial
    begin
      // Create waveform dump file for simulation analysis
      $dumpfile("dump.vcd");     
      $dumpvars(1);             

      // Initialize signals
      clk = 0; 
      rst = 1;                   // Assert reset initially

      // After 10 time units, release reset and load parallel data
      #10 rst = 0; ena = 1; sin = 4'b1100;  

      // After 6 time units, disable load (ena=0) so shifting begins
      #6 ena = 0;               

      // Allow shifting for 50 time units before ending simulation
      #50 $finish;
    end

  // Monitor values continuously during simulation
  initial
    $monitor("time=%0t clk=%b rst=%b ena=%b sin=%b q=%b", 
              $time, clk, rst, ena, sin, q);
endmodule
