// Parameterized Parallel-In Parallel-Out (PIPO) Register Design
parameter N = 4;   // Define the width of the register (default is 4 bits)

module pipo(clk, rst, sin, q);
  input clk, rst;          // Clock and reset signals
  input [3:0] sin;         // 4-bit parallel input data
  output reg [(N-1):0] q;  // N-bit parallel output register

  // Always block triggered on rising edge of clock or reset
  always @(posedge clk or posedge rst)
    begin
      if (rst)             // If reset is active (high)
        q <= 0;            // Clear the register (set output to 0)
      else
        q = sin;           // Load input data into the register on clock edge
    end
endmodule
// Test bench code for the verification of the Design
// Testbench for Parallel-In Parallel-Out (PIPO) Register
module tb();
  reg clk, rst;             // Clock and reset signals
  reg [3:0] sin;            // 4-bit input data
  wire [(N-1):0] q;         // N-bit output from DUT (Device Under Test)

  // Instantiate the PIPO module
  pipo DUT(clk, rst, sin, q);

  // Clock generation: toggles every 5 time units
  always #5 clk = ~clk;

  // Initial block for stimulus
  initial
    begin
      // Create a waveform dump file for simulation analysis
      $dumpfile("dump.vcd");     
      $dumpvars(1);             

      // Initialize signals
      clk = 0; 
      rst = 1;                  // Assert reset initially
      sin = 4'b0000;            // Input starts at 0

      #5 rst = 0;               // Deassert reset after 5 time units

      // Apply input stimulus
      #10 sin = 4'b1010;        // Load new data into register
      #10 sin = 4'b1111;        // Change input again
      #10 sin = 4'b0101;        // Another input pattern

      // End simulation after 30 time units
      #30 $finish;
    end

  // Monitor values continuously during simulation
  initial
    $monitor("time=%0t clk=%b rst=%b sin=%b q=%b", $time, clk, rst, sin, q);
endmodule
