// Testbench for ALU module
module tb();

  // Declare testbench signals
  reg [7:0] op1, op2;        // 8-bit operands
  reg [3:0] command;         // 4-bit command to select ALU operation
  reg enable;                // Enable signal
  wire [15:0] out;           // 16-bit output from ALU
  integer i;                 // Loop variable

  // Instantiate the ALU (Device Under Test)
  alu DUT(op1, op2, enable, out, command);

  // Initial block to apply stimulus
  initial begin
    enable = 1;              // Enable ALU
    // Loop through all 16 possible command values (0 to 15)
    for (i = 0; i < 16; i = i + 1) begin
      command = i;           // Apply command
      op1 = 8'd10;           // Operand1 = 10 (decimal)
      op2 = 8'd5;            // Operand2 = 5 (decimal)
      #5;                    // Wait for 5 time units before next command
    end
    #10 $finish;             // End simulation after loop
  end

  // Monitor block to display values during simulation
  initial begin
    $monitor($time, " command=%b, op1=%d, op2=%d, out=%b", 
             command, op1, op2, out);
    // $monitor prints whenever any of the listed signals change
    // %b = binary format, %d = decimal format
  end

endmodule
