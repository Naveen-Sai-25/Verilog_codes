// Code your design here
// ALU - Arithmetic Logic Unit
// Define operation codes (4-bit) for different ALU operations
`define ADD   4'b0000   // Addition
`define SUB   4'b0001   // Subtraction
`define INC   4'b0010   // Increment operand1
`define DEC   4'b0011   // Decrement operand1
`define MUL   4'b0100   // Multiplication
`define DIV   4'b0101   // Division (operand1 / 2 here)
`define SHL   4'b0110   // Shift Left operand1 by 1
`define SHR   4'b0111   // Shift Right operand1 by 1
`define AND   4'b1000   // Bitwise AND
`define OR    4'b1001   // Bitwise OR
`define NAND  4'b1010   // Bitwise NAND
`define NOR   4'b1011   // Bitwise NOR
`define XOR   4'b1100   // Bitwise XOR
`define XNOR  4'b1101   // Bitwise XNOR
`define NOT   4'b1110   // Bitwise NOT of operand1
`define BUF   4'b1111   // Buffer (pass operand1 directly)

module alu(operand1, operand2, enable, out, command);
  // Inputs
  input [7:0] operand1, operand2;   // 8-bit operands
  input [3:0] command;              // 4-bit command to select operation
  input enable;                     // Enable signal

  // Output
  output reg [15:0] out;            // 16-bit output (to handle multiplication results)

  // Always block triggered whenever inputs change
  always @(operand1, operand2, command, enable) begin
    if (enable == 1) begin
      // Perform operation based on command
      case (command)
        `ADD  : out = operand1 + operand2;       // Addition of two operands
        `SUB  : out = operand1 - operand2;       // Subtraction
        `INC  : out = operand1 + 1;              // Increment operand1
        `DEC  : out = operand1 - 1;              // Decrement operand1
        `MUL  : out = operand1 * operand2;       // Multiplication
        `DIV  : out = operand1 / 2;              // Division (currently divides operand1 by 2)
        `SHL  : out = operand1 << 1;             // Shift left by 1 bit
        `SHR  : out = operand1 >> 1;             // Shift right by 1 bit
        `AND  : out = operand1 & operand2;       // Bitwise AND
        `OR   : out = operand1 | operand2;       // Bitwise OR
        `NAND : out = ~(operand1 & operand2);    // Bitwise NAND
        `NOR  : out = ~(operand1 | operand2);    // Bitwise NOR
        `XOR  : out = operand1 ^ operand2;       // Bitwise XOR
        `XNOR : out = ~(operand1 ^ operand2);    // Bitwise XNOR
        `NOT  : out = ~operand1;                 // Bitwise NOT of operand1
        `BUF  : out = operand1;                  // Buffer (direct output of operand1)
      endcase
    end else begin
      // If enable is low, output is reset to 0
      out = 0;
    end
  end
endmodule
