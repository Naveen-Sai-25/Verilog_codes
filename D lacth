// Primitive definition for D latch with reset
primitive dlatch(qn, d, ctrl, rst);
  input d, ctrl, rst;       // inputs: data, control, reset
  output reg qn;            // output: latch state

  // Truth table
  table
    // d  ctrl rst  q  Qn
       ?   ?    1 : ? : 0;  // reset active → output 0
       ?   0    0 : ? : 0;  // hold state when q=0
       ?   0    0 : 1 : 1;  // hold state when q=1
       0   1    0 : ? : 0;  // latch input 0
       1   1    0 : ? : 1;  // latch input 1
  endtable
endprimitive

// Module wrapper for the D latch
module d_latch(d, ctrl, rst, qn);
  input d, ctrl, rst;       // inputs
  output qn;                // output

  dlatch l1(qn, d, ctrl, rst); // instantiate primitive
endmodule
// Test bench code of verification of Design
// Testbench for D latch
module tb();
  reg d, ctrl, rst;        // inputs: data, control, reset
  wire qn;                 // output: latch output

  // Instantiate the D latch module
  d_latch DUT(d, ctrl, rst, qn);
  integer i;               // loop variable
  initial 
    begin
      // Apply all 8 possible input combinations (d, ctrl, rst)
      for(i=0; i<8; i=i+1)
        begin
          {d, ctrl, rst} = i; // assign inputs using loop counter
          #5;                 // wait 5 time units
        end
    end

  // Monitor changes in signals and print them
  initial
    $monitor("d=%b, ctrl=%b, rst=%b, qn=%b", d, ctrl, rst, qn);
endmodule
